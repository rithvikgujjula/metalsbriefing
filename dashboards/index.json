<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MetalsDesk — Company Dashboards</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  :root {
    --bg: #0c0f14; --panel: #141922; --panel2: #1a2130; --border: #263042;
    --text: #dce3ee; --muted: #8494ab; --accent: #e8a33d; --accent-dim: #b57f2e;
    --green: #4cc38a; --red: #e5534b;
    --mono: "SF Mono", "Cascadia Mono", Consolas, monospace;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; min-height: 100vh; }
  .wrap { max-width: 1040px; margin: 0 auto; padding: 24px 20px 80px; }

  header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 20px; flex-wrap: wrap; gap: 8px; }
  header h1 { font-size: 18px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; }
  header h1 span { color: var(--accent); }
  header .sub { color: var(--muted); font-size: 12px; font-family: var(--mono); }
  #settingsBtn { background: none; border: 1px solid var(--border); color: var(--muted); border-radius: 6px; padding: 5px 10px; font-size: 12px; cursor: pointer; }
  #settingsBtn:hover { color: var(--text); border-color: var(--muted); }

  .panel { background: var(--panel); border: 1px solid var(--border); border-radius: 10px; padding: 18px; margin-bottom: 16px; }

  #keyPanel label { display: block; font-size: 12px; color: var(--muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em; }
  #keyPanel input { width: 100%; background: var(--panel2); border: 1px solid var(--border); color: var(--text); border-radius: 6px; padding: 10px 12px; font-family: var(--mono); font-size: 13px; }
  #keyPanel input:focus { outline: none; border-color: var(--accent-dim); }
  #keyPanel .hint { font-size: 12px; color: var(--muted); margin-top: 10px; line-height: 1.5; }
  #keyPanel .hint a { color: var(--accent); }
  #keyPanel .row { display: flex; gap: 10px; margin-top: 12px; }

  #searchForm { display: flex; gap: 10px; flex-wrap: wrap; }
  #companyInput { flex: 1 1 260px; background: var(--panel2); border: 1px solid var(--border); color: var(--text); border-radius: 8px; padding: 13px 16px; font-size: 16px; }
  #companyInput:focus { outline: none; border-color: var(--accent-dim); }
  #companyInput::placeholder { color: #55647c; }
  select { background: var(--panel2); border: 1px solid var(--border); color: var(--text); border-radius: 8px; padding: 0 12px; font-size: 13px; cursor: pointer; }
  .btn { background: var(--accent); color: #14100a; border: none; border-radius: 8px; padding: 13px 22px; font-size: 14px; font-weight: 700; cursor: pointer; letter-spacing: 0.03em; }
  .btn:hover { background: #f2b352; }
  .btn:disabled { background: var(--accent-dim); opacity: 0.6; cursor: not-allowed; }
  .btn-ghost { background: none; border: 1px solid var(--border); color: var(--muted); font-weight: 500; }
  .btn-ghost:hover { background: var(--panel2); color: var(--text); }

  /* market tape */
  #marketTitle { font-size: 12px; color: var(--accent); text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 10px; }
  #marketTitle span { color: var(--muted); text-transform: none; letter-spacing: 0; font-family: var(--mono); font-size: 11px; }
  #marketChips { display: flex; flex-wrap: wrap; gap: 8px; }
  .mchip { background: var(--panel2); border: 1px solid var(--border); border-radius: 8px; padding: 6px 10px; font-family: var(--mono); font-size: 12px; color: var(--text); }
  .mchip .sym { color: var(--muted); }
  .mchip .up { color: var(--green); }
  .mchip .dn { color: var(--red); }

  /* showcase + history chips */
  .chiprow h2 { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 10px; }
  .chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip { background: var(--panel2); border: 1px solid var(--border); color: var(--text); border-radius: 20px; padding: 6px 14px; font-size: 13px; cursor: pointer; }
  .chip:hover { border-color: var(--accent-dim); }
  .chip span { color: var(--muted); font-size: 11px; margin-left: 6px; font-family: var(--mono); }

  #status { display: flex; align-items: center; gap: 12px; font-family: var(--mono); font-size: 13px; color: var(--muted); }
  .pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); animation: pulse 1.1s ease-in-out infinite; flex-shrink: 0; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.25; } }
  #stopBtn { margin-left: auto; }

  #errorBox { display: none; border: 1px solid var(--red); background: rgba(229,83,75,0.08); color: #f0b3af; border-radius: 8px; padding: 12px 16px; font-size: 13px; margin-bottom: 16px; }
  #errorBox.on { display: block; }

  /* dashboard */
  #dash { display: none; }
  #dash.on { display: block; }
  .dhead { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 10px; margin-bottom: 14px; }
  .dhead h2 { font-size: 24px; font-weight: 700; }
  .dhead .desc { color: var(--muted); font-size: 13px; margin-top: 3px; }
  .dhead .meta { font-family: var(--mono); font-size: 11px; color: var(--muted); margin-top: 6px; }
  .dactions { display: flex; gap: 8px; }
  .dactions button { font-size: 12px; padding: 6px 12px; }

  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 14px; }
  @media (max-width: 640px) { .grid { grid-template-columns: 1fr; } }
  .card { background: var(--panel); border: 1px solid var(--border); border-radius: 10px; padding: 16px 18px; }
  .card.wide { grid-column: 1 / -1; }
  .card h3 { font-size: 12px; color: var(--accent); text-transform: uppercase; letter-spacing: 0.08em; border-bottom: 1px solid var(--border); padding-bottom: 6px; margin-bottom: 10px; font-weight: 500; }
  .card ul { margin: 0 0 4px 18px; }
  .card li { margin-bottom: 6px; font-size: 13px; line-height: 1.55; }
  .card .sh { font-size: 12px; color: #fff; font-weight: 600; margin: 10px 0 6px; }
  .card table { border-collapse: collapse; width: 100%; font-size: 12px; }
  .card th { background: var(--panel2); color: var(--muted); text-transform: uppercase; font-size: 10px; letter-spacing: 0.05em; border: 1px solid var(--border); padding: 5px 8px; text-align: left; font-weight: 500; }
  .card td { border: 1px solid var(--border); padding: 5px 8px; line-height: 1.45; }
  .card td.k { color: var(--muted); white-space: nowrap; }
  .card b { color: #fff; }
  .card em { color: var(--muted); }
  .card a { color: var(--accent); text-decoration: none; font-size: 12px; }
  .card a:hover { text-decoration: underline; }
  .src { font-size: 11px; color: var(--muted); line-height: 1.9; }

  .disclaimer { color: #55647c; font-size: 11px; margin-top: 24px; line-height: 1.5; }

  @media print {
    body { background: #fff; color: #111; }
    header, #keyPanel, #searchPanel, #marketPanel, #showcase, #history, #statusPanel, .dactions, .disclaimer, #errorBox { display: none !important; }
    #dash { display: block !important; }
    .card { border-color: #ccc; background: #fff; }
    .card h3 { color: #7a5510; border-color: #ccc; }
    .card td, .card th { border-color: #bbb; color: #111; }
    .card th { background: #f2f2f2; color: #444; }
    .card li, .dhead h2 { color: #111; }
    .card b { color: #111; }
  }
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div>
      <h1>Metals<span>Desk</span></h1>
      <div class="sub">company dashboards // steel · aluminum · base metals</div>
    </div>
    <button id="settingsBtn">API key</button>
  </header>

  <div class="panel" id="keyPanel" style="display:none">
    <label for="keyInput">Anthropic API key (only needed to generate NEW companies)</label>
    <input type="password" id="keyInput" placeholder="sk-ant-...">
    <div class="hint">
      Stored only in this browser — sent nowhere except directly to Anthropic.
      Get a key at <a href="https://console.anthropic.com/settings/keys" target="_blank" rel="noopener">console.anthropic.com</a>.
      Showcase dashboards below are free to view, no key needed.
    </div>
    <div class="row">
      <button class="btn" id="saveKeyBtn" type="button">Save key</button>
      <button class="btn btn-ghost" id="clearKeyBtn" type="button">Clear key</button>
    </div>
  </div>

  <div class="panel" id="marketPanel" style="display:none">
    <div id="marketTitle">Market tape <span id="marketMeta"></span></div>
    <div id="marketChips"></div>
    <div style="position:relative;height:170px;margin-top:12px;">
      <canvas id="hrcChart" role="img" aria-label="90-day CME HRC futures price chart"></canvas>
    </div>
  </div>

  <div class="panel chiprow" id="showcase" style="display:none">
    <h2>Showcase dashboards (free, no key needed)</h2>
    <div class="chips" id="showcaseChips"></div>
  </div>

  <div class="panel" id="searchPanel">
    <form id="searchForm">
      <input id="companyInput" type="text" placeholder="Generate a new company — e.g. Klöckner, Ryerson, Commercial Metals…" autocomplete="off">
      <select id="depthSelect" title="Research depth">
        <option value="standard">Standard (~14 searches)</option>
        <option value="deep">Deep (~22 searches)</option>
      </select>
      <select id="modelSelect" title="Model">
        <option value="claude-sonnet-5">Sonnet (best)</option>
        <option value="claude-haiku-4-5-20251001">Haiku (cheap/fast)</option>
      </select>
      <button class="btn" id="goBtn" type="submit">Build dashboard</button>
    </form>
  </div>

  <div id="errorBox"></div>

  <div class="panel" id="statusPanel" style="display:none">
    <div id="status">
      <div class="pulse"></div>
      <div id="statusText">Starting…</div>
      <button class="btn btn-ghost" id="stopBtn" type="button">Stop</button>
    </div>
  </div>

  <div id="dash">
    <div class="dhead">
      <div>
        <h2 id="dName"></h2>
        <div class="desc" id="dDesc"></div>
        <div class="meta" id="dMeta"></div>
      </div>
      <div class="dactions">
        <button class="btn btn-ghost" id="dlBtn" type="button">Download JSON</button>
        <button class="btn btn-ghost" id="printBtn" type="button">Print / PDF</button>
      </div>
    </div>
    <div class="grid" id="grid"></div>
  </div>

  <div class="panel chiprow" id="history" style="display:none">
    <h2>Your generated dashboards (saved in this browser)</h2>
    <div class="chips" id="historyList"></div>
  </div>

  <div class="disclaimer">
    Research generated with AI from public web sources; market data via OpenBB (free feeds). Figures may be incomplete or out of date — verify before trading or extending credit. Not investment advice.
  </div>
</div>

<script>
"use strict";

const $ = id => document.getElementById(id);
const API_URL = "https://api.anthropic.com/v1/messages";
const KEY_STORE = "mdb_api_key";
const HIST_STORE = "mdb_dash_v2";

let controller = null;
let currentDash = null;
let capChart = null;

/* ---------- system prompt: research + strict JSON output ---------- */
const SYSTEM_PROMPT = `You are a commercial intelligence analyst on a physical metals trading desk, writing for professional metals traders. They scan, they don't read. Telegraphic style: short bullets, fragments over sentences, numbers and dates in every line, zero filler. Every bullet string ≤ 20 words. NEVER use em dashes or en dashes; use colons or commas. No generic filler a trader already knows.

RESEARCH REQUIREMENTS (use web search aggressively before writing):
1. ASSETS: completeness is mandatory. Search "{company} locations", "{company} 10-K Item 2 properties", official facilities page. Cross-check company-reported facility count; list every production asset. If >35 sites, list production assets individually, group minor offices by region with counts. State total count and source in assets.note.
2. COUNTERPARTIES: named entities are the point. Search "{company} supply agreement", "{company} joint venture", deal press releases. Include energy/power agreements, JV partners with stakes, contract vs spot mix with %. Mark inferred entries "(likely)"; write "names not disclosed" where true.
3. MARKET: search CURRENT prices for the metals this company trades (HRC/CRC/plate/rebar, busheling/shred, LME complex, Midwest premium, stainless surcharges). Every price needs a date. Skip prices you cannot find; never guess.
4. Recent developments: last 12 months, dated, most recent first.
5. Tariffs: specific programs and rates (Section 232 50%, named AD/CVD orders), import reliance, exclusions with dates, quantified impacts. Ban vague lines.

OUTPUT: reply with ONLY a valid JSON object, no markdown fences, no commentary before or after. Exact schema:
{
 "company": "Name",
 "slug": "lowercase-name",
 "ticker": "NUE or null",
 "descriptor": "one line: what they are, HQ, ticker",
 "generated": "YYYY-MM-DD",
 "snapshot": [["Label","Value ≤8 words"], ... max 7 pairs],
 "assets": {
   "note": "total facility count + source",
   "sites": [{"name":"","loc":"","type":"","cap":"human readable or 'n/d'","cap_mt": 0.0}, ...]
 },
 "counterparties": {
   "suppliers": ["**Name**: what they supply, agreement terms", ...],
   "jvs": ["**Partner**: stake, asset, product", ...],
   "customers": ["named account or channel structure with %", ...]
 },
 "angles": ["4-7 sharp trader-actionable bullets", ...],
 "developments": [{"date":"Mon YYYY","event":"≤15 words"}, ... 5-10 items],
 "tariffs": ["4-6 specific bullets", ...],
 "financials": ["4-6 bullets with figures", ...],
 "market": ["5-8 dated price/tape bullets", ...],
 "sources": [{"t":"short title","u":"https://..."}, ...]
}
cap_mt = annual capacity in million metric tons as a number, 0 if unknown/not applicable. Bold with **text** is allowed inside strings; no other markdown.`;

/* ---------- key handling ---------- */
function getKey() { return localStorage.getItem(KEY_STORE) || ""; }
function toggleKeyPanel(force) {
  const p = $("keyPanel");
  const show = force !== undefined ? force : p.style.display === "none";
  p.style.display = show ? "block" : "none";
  if (show) { $("keyInput").value = getKey(); $("keyInput").focus(); }
}
$("settingsBtn").onclick = () => toggleKeyPanel();
$("saveKeyBtn").onclick = () => {
  const k = $("keyInput").value.trim();
  if (!k.startsWith("sk-ant-")) { showError("That doesn't look like an Anthropic key (should start with sk-ant-)."); return; }
  localStorage.setItem(KEY_STORE, k); hideError(); toggleKeyPanel(false);
};
$("clearKeyBtn").onclick = () => { localStorage.removeItem(KEY_STORE); $("keyInput").value = ""; };

/* ---------- ui helpers ---------- */
function showError(msg) { const e = $("errorBox"); e.textContent = msg; e.classList.add("on"); }
function hideError() { $("errorBox").classList.remove("on"); }
function setStatus(msg) { $("statusText").textContent = msg; }
function statusOn(on) { $("statusPanel").style.display = on ? "block" : "none"; }
function esc(s) { return String(s == null ? "" : s).replace(/[&<>"']/g, m => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[m])); }
function fmt(s) {
  return esc(s)
    .replace(/\*\*(.+?)\*\*/g, "<b>$1</b>")
    .replace(/\(likely\)/g, "<em>(likely)</em>");
}

/* ---------- dashboard rendering ---------- */
function card(title, bodyHtml, wide) {
  return "<div class='card" + (wide ? " wide" : "") + "'><h3>" + esc(title) + "</h3>" + bodyHtml + "</div>";
}
function ulist(items) {
  if (!Array.isArray(items) || !items.length) return "<ul><li>not available</li></ul>";
  return "<ul>" + items.map(i => "<li>" + fmt(i) + "</li>").join("") + "</ul>";
}

function renderDashboard(d, originLabel) {
  currentDash = d;
  $("dName").textContent = (d.company || "?") + (d.ticker ? " (" + d.ticker + ")" : "");
  $("dDesc").textContent = d.descriptor || "";
  $("dMeta").textContent = (originLabel || "") + (d.generated ? " · generated " + d.generated : "");

  let h = "";

  const snap = Array.isArray(d.snapshot) ? d.snapshot : [];
  h += card("Snapshot",
    "<table>" + snap.map(p => "<tr><td class='k'>" + esc(p[0]) + "</td><td>" + fmt(p[1]) + "</td></tr>").join("") + "</table>");

  const sites = (d.assets && Array.isArray(d.assets.sites)) ? d.assets.sites : [];
  let assetHtml = d.assets && d.assets.note ? "<div style='font-size:12px;color:var(--muted);margin-bottom:8px;'>" + fmt(d.assets.note) + "</div>" : "";
  assetHtml += "<table><tr><th>Asset</th><th>Where</th><th>Type</th><th>Capacity</th></tr>" +
    sites.map(s => "<tr><td>" + fmt(s.name) + "</td><td>" + fmt(s.loc) + "</td><td>" + fmt(s.type) + "</td><td>" + fmt(s.cap) + "</td></tr>").join("") + "</table>";
  const capSites = sites.filter(s => Number(s.cap_mt) > 0);
  if (capSites.length >= 2) {
    assetHtml += "<div style='position:relative;height:" + Math.max(140, capSites.length * 34 + 60) + "px;margin-top:12px;'><canvas id='capCanvas' role='img' aria-label='Capacity by asset, million tonnes per year'></canvas></div>";
  }
  h += card("Asset Footprint", assetHtml, true);

  h += card("Market Context", ulist(d.market));
  h += card("Commercial Angles", ulist(d.angles));

  const cp = d.counterparties || {};
  h += card("Counterparties",
    "<div class='sh'>Suppliers & inputs</div>" + ulist(cp.suppliers) +
    "<div class='sh'>JV partners</div>" + ulist(cp.jvs) +
    "<div class='sh'>Customers & channels</div>" + ulist(cp.customers));

  const dev = Array.isArray(d.developments) ? d.developments : [];
  h += card("Recent Developments",
    "<ul>" + dev.map(x => "<li><b>" + esc(x.date) + ":</b> " + fmt(x.event) + "</li>").join("") + "</ul>");

  h += card("Trade & Tariff Exposure", ulist(d.tariffs));
  h += card("Financial Position", ulist(d.financials));

  const src = Array.isArray(d.sources) ? d.sources : [];
  h += card("Sources",
    "<div class='src'>" + src.map(s => "<a href='" + esc(s.u) + "' target='_blank' rel='noopener'>" + esc(s.t) + "</a>").join(" · ") + "</div>", true);

  $("grid").innerHTML = h;
  $("dash").classList.add("on");

  if (capChart) { capChart.destroy(); capChart = null; }
  const canvas = document.getElementById("capCanvas");
  if (canvas && window.Chart && capSites.length >= 2) {
    capChart = new Chart(canvas, {
      type: "bar",
      data: {
        labels: capSites.map(s => s.name),
        datasets: [{ data: capSites.map(s => Number(s.cap_mt)), backgroundColor: "#e8a33d", borderRadius: 4, maxBarThickness: 22 }]
      },
      options: { indexAxis: "y", responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: { x: { ticks: { color: "#8494ab", callback: v => v + "Mt" }, grid: { color: "#263042" } },
                  y: { ticks: { color: "#8494ab", font: { size: 11 } }, grid: { display: false } } } }
    });
  }
  window.scrollTo({ top: 0, behavior: "smooth" });
}

/* ---------- download ---------- */
$("dlBtn").onclick = () => {
  if (!currentDash) return;
  const slug = currentDash.slug || (currentDash.company || "dashboard").toLowerCase().replace(/[^a-z0-9]+/g, "-");
  const blob = new Blob([JSON.stringify(currentDash, null, 1)], { type: "application/json" });
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = slug + ".json";
  a.click();
  URL.revokeObjectURL(a.href);
};
$("printBtn").onclick = () => window.print();

/* ---------- showcase (pre-baked) ---------- */
async function loadShowcase() {
  try {
    const res = await fetch("dashboards/index.json", { cache: "no-store" });
    if (!res.ok) return;
    const list = await res.json();
    const box = $("showcaseChips");
    box.innerHTML = "";
    list.forEach(item => {
      const c = document.createElement("button");
      c.className = "chip"; c.type = "button";
      c.innerHTML = esc(item.company) + (item.ticker ? "<span>" + esc(item.ticker) + "</span>" : "");
      c.onclick = async () => {
        try {
          const r = await fetch("dashboards/" + item.slug + ".json", { cache: "no-store" });
          if (!r.ok) throw new Error("could not load " + item.slug);
          renderDashboard(await r.json(), "SHOWCASE");
          hideError();
        } catch (e) { showError(e.message); }
      };
      box.appendChild(c);
    });
    if (list.length) $("showcase").style.display = "block";
  } catch { /* no showcase folder */ }
}

/* ---------- history ---------- */
function loadHistory() { try { return JSON.parse(localStorage.getItem(HIST_STORE)) || []; } catch { return []; } }
function saveToHistory(d) {
  let h = loadHistory().filter(x => (x.company || "").toLowerCase() !== (d.company || "").toLowerCase());
  h.unshift(d); h = h.slice(0, 15);
  try { localStorage.setItem(HIST_STORE, JSON.stringify(h)); } catch { }
  renderHistory();
}
function renderHistory() {
  const h = loadHistory();
  $("history").style.display = h.length ? "block" : "none";
  $("historyList").innerHTML = "";
  h.forEach(d => {
    const c = document.createElement("button");
    c.className = "chip"; c.type = "button";
    c.innerHTML = esc(d.company) + "<span>" + esc(d.generated || "") + "</span>";
    c.onclick = () => renderDashboard(d, "YOUR BUILD");
    $("historyList").appendChild(c);
  });
}

/* ---------- market tape (OpenBB data layer) ---------- */
async function loadMarket() {
  try {
    const res = await fetch("market.json", { cache: "no-store" });
    if (!res.ok) return;
    const m = await res.json();
    const chips = $("marketChips");
    chips.innerHTML = "";
    (m.tape || []).forEach(t => {
      const up = Number(t.chg_pct) >= 0;
      const el = document.createElement("div");
      el.className = "mchip";
      el.innerHTML = "<span class='sym'>" + esc(t.name || t.sym) + "</span> " +
        Number(t.last).toLocaleString(undefined, { maximumFractionDigits: 2 }) + " " +
        "<span class='" + (up ? "up" : "dn") + "'>" + (up ? "▲" : "▼") +
        Math.abs(Number(t.chg_pct)).toFixed(1) + "%</span>";
      chips.appendChild(el);
    });
    $("marketMeta").textContent = "· powered by OpenBB · " + new Date(m.updated).toLocaleDateString();
    if (window.Chart && Array.isArray(m.hrc_series) && m.hrc_series.length) {
      new Chart($("hrcChart"), {
        type: "line",
        data: { labels: m.hrc_series.map(p => p.d.slice(5)),
          datasets: [{ data: m.hrc_series.map(p => p.c), borderColor: "#e8a33d",
            backgroundColor: "rgba(232,163,61,0.12)", borderWidth: 2, pointRadius: 0, tension: 0.25, fill: true }] },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } },
          scales: { y: { ticks: { color: "#8494ab", callback: v => "$" + v }, grid: { color: "#263042" } },
                    x: { ticks: { color: "#8494ab", maxTicksLimit: 8 }, grid: { display: false } } } }
      });
    }
    $("marketPanel").style.display = "block";
  } catch { /* market.json not generated yet */ }
}

/* ---------- generation (on-demand) ---------- */
$("searchForm").addEventListener("submit", e => {
  e.preventDefault();
  const company = $("companyInput").value.trim();
  if (!company) return;
  if (!getKey()) { toggleKeyPanel(true); showError("Add your Anthropic API key to generate new companies. Showcase dashboards are free."); return; }
  buildDashboard(company);
});
$("stopBtn").onclick = () => { if (controller) controller.abort(); };

async function apiStream(body, state) {
  const res = await fetch(API_URL, {
    method: "POST", signal: controller.signal,
    headers: { "content-type": "application/json", "x-api-key": getKey(),
      "anthropic-version": "2023-06-01", "anthropic-dangerous-direct-browser-access": "true" },
    body: JSON.stringify(body)
  });
  if (!res.ok) {
    let msg = "API error (" + res.status + ")";
    try { const err = await res.json(); if (err.error && err.error.message) msg = err.error.message; } catch { }
    if (res.status === 401) msg = "Invalid API key — check it in the API key panel.";
    if (res.status === 429) msg = "Rate limited — wait a moment and retry. (" + msg + ")";
    throw new Error(msg);
  }
  const reader = res.body.getReader();
  const decoder = new TextDecoder();
  let buf = "", cur = null, curJson = "", stopReason = null;
  const blocks = [];
  while (true) {
    const { done, value } = await reader.read();
    if (done) break;
    buf += decoder.decode(value, { stream: true });
    const lines = buf.split("\n");
    buf = lines.pop();
    for (const line of lines) {
      if (!line.startsWith("data:")) continue;
      const payload = line.slice(5).trim();
      if (!payload) continue;
      let ev; try { ev = JSON.parse(payload); } catch { continue; }
      if (ev.type === "content_block_start") {
        const cb = ev.content_block || {};
        curJson = "";
        if (cb.type === "text") { cur = { type: "text", text: cb.text || "", citations: [] }; setStatus("Writing dashboard (" + state.searches + " searches done)…"); }
        else if (cb.type === "server_tool_use") { cur = { type: "server_tool_use", id: cb.id, name: cb.name, input: {} }; setStatus("Searching the web…"); }
        else { cur = JSON.parse(JSON.stringify(cb)); }
      } else if (ev.type === "content_block_delta") {
        const d = ev.delta || {};
        if (d.type === "text_delta" && cur && cur.type === "text") { cur.text += d.text; state.text += d.text; }
        else if (d.type === "citations_delta" && cur && cur.type === "text") { if (d.citation) cur.citations.push(d.citation); }
        else if (d.type === "input_json_delta" && cur && cur.type === "server_tool_use") {
          curJson += d.partial_json || "";
          try { const q = JSON.parse(curJson).query; if (q) setStatus("Search " + (state.searches + 1) + ": “" + q + "”"); } catch { }
        }
      } else if (ev.type === "content_block_stop") {
        if (cur) {
          if (cur.type === "server_tool_use") { try { cur.input = JSON.parse(curJson || "{}"); } catch { cur.input = {}; } state.searches++; }
          if (cur.type === "text" && !cur.citations.length) delete cur.citations;
          if (cur.type !== "text" || cur.text) blocks.push(cur);
        }
        cur = null;
      } else if (ev.type === "message_delta") {
        if (ev.delta && ev.delta.stop_reason) stopReason = ev.delta.stop_reason;
      } else if (ev.type === "error") {
        throw new Error(ev.error && ev.error.message ? ev.error.message : "Stream error");
      }
    }
  }
  return { blocks, stopReason };
}

async function runToCompletion(baseParams, messages, maxTurns, state) {
  let msgs = messages;
  for (let turn = 0; turn < maxTurns; turn++) {
    const { blocks, stopReason } = await apiStream(Object.assign({}, baseParams, { messages: msgs }), state);
    if ((stopReason === "pause_turn" || stopReason === "max_tokens") && blocks.length) {
      const last = blocks[blocks.length - 1];
      if (last.type === "text") last.text = last.text.replace(/\s+$/, "");
      msgs = msgs.concat([{ role: "assistant", content: blocks }]);
      continue;
    }
    return;
  }
}

function parseDashJson(text) {
  const a = text.indexOf("{");
  const b = text.lastIndexOf("}");
  if (a < 0 || b <= a) throw new Error("no JSON found");
  return JSON.parse(text.slice(a, b + 1));
}

async function buildDashboard(company) {
  hideError();
  $("goBtn").disabled = true;
  statusOn(true);
  setStatus("Contacting Claude…");
  const deep = $("depthSelect").value === "deep";
  const baseParams = {
    model: $("modelSelect").value,
    max_tokens: deep ? 16000 : 10000,
    stream: true,
    system: SYSTEM_PROMPT,
    tools: [{ type: "web_search_20250305", name: "web_search", max_uses: deep ? 22 : 14 }]
  };
  const userMsg = {
    role: "user",
    content: "Build the dashboard JSON for: " + company +
      "\n\nToday's date: " + new Date().toDateString() +
      ". Research first. Reserve 3+ searches for assets (locations page, 10-K properties), 2 for counterparty agreements/JVs, 2 for current market prices." +
      (deep ? " DEEP mode: dig into filings and trade press (AMM/Fastmarkets/SMU)." : "") +
      " Then output ONLY the JSON object."
  };
  controller = new AbortController();
  const state = { searches: 0, text: "" };
  try {
    await runToCompletion(baseParams, [userMsg], 6, state);
    let dash;
    try {
      dash = parseDashJson(state.text);
    } catch {
      setStatus("Fixing JSON…");
      const repairMsgs = [userMsg,
        { role: "assistant", content: [{ type: "text", text: state.text.replace(/\s+$/, "") || "(empty)" }] },
        { role: "user", content: "That output was not valid JSON. Reply with ONLY the corrected, complete, valid JSON object. No commentary, no fences." }];
      state.text = "";
      await runToCompletion(baseParams, repairMsgs, 3, state);
      dash = parseDashJson(state.text);
    }
    if (!dash.generated) dash.generated = new Date().toISOString().slice(0, 10);
    renderDashboard(dash, "YOUR BUILD · " + state.searches + " searches");
    saveToHistory(dash);
    $("companyInput").value = "";
  } catch (err) {
    if (err.name === "AbortError") showError("Stopped.");
    else showError(err.message || String(err));
  } finally {
    statusOn(false);
    $("goBtn").disabled = false;
    controller = null;
  }
}

/* ---------- init ---------- */
loadShowcase();
loadMarket();
renderHistory();
</script>
</body>
</html>
